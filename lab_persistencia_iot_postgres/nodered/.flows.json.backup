    {
        "id": "5f7adf3cee19e6d2",
        "type": "function",
        "z": "2c6d61a3908a29db",
        "name": "function 2",
        "func": "const msgs = msg.payload;\n\nif (!msgs || msgs.length === 0) {\n    node.warn(\"Payload vacío\");\n    return null;\n}\n\nlet placeholders = [];\nlet params = [];\n\nmsgs.forEach((m, index) => {\n    const base = index * 3;\n\n    placeholders.push(\n        `($${base + 1}, $${base + 2}, to_timestamp($${base + 3}))`\n    );\n\n    params.push(\n        m.device_id ?? null,\n        m.msg ?? null,\n        m.timestamp ?? null  \n    );\n});\n\nmsg.query = `\n    INSERT INTO logs_comandos (device_id, comando_texto, fecha)\n    VALUES ${placeholders.join(\", \")}\n`;\n\nmsg.params = params;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
