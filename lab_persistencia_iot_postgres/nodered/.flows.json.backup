    {
        "id": "0bfa169c615c6323",
        "type": "function",
        "z": "2c6d61a3908a29db",
        "name": "function 1",
        "func": "const bulk = msg.payload;\nmsg.params = [];\nlet placeholders = [];\n\nfor (let r of bulk) {\n    let base = msg.params.length;\n    msg.params.push(r.temperatura, r.humedad, r.ir_proximidad, r.potenciometro, r.device_id);\n    placeholders.push(`($${base+1}, $${base+2}, $${base+3}, $${base+4}, $${base+5})`);\n}\n\nmsg.query = `INSERT INTO lecturas_sensores (temperatura, humedad, proximidad_ir, potenciometro, device_id) VALUES ${placeholders.join(\", \")}`;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 480,
