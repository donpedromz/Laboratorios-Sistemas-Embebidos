SUPABASE_URL=
SUPABASE_KEY=

# Tabla de telemetria
SUPABASE_TABLE=telemetria_iot

# Tabla de usuarios
SUPABASE_USERS_TABLE=users

# Parametros de hash de password (PBKDF2)
PASSWORD_HASH_ITERATIONS=100000

# MQTT 
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
