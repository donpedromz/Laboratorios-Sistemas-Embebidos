MQTT_CLIENT_ID=python_temperatura_humedad_subscriber
DEVICE_ID=ESP32-TempHum
MQTT_TOPIC_READING=sensor/ambient/reading
MQTT_TOPIC_STATUS=sensor/esp32/status
MQTT_TOPIC_ERROR=sensor/esp32/error